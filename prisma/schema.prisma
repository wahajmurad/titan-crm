generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("TEAM") // OWNER or TEAM
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions    Permission[]
  activities     Activity[]
  assignedLeads  Lead[] @relation("AssignedTo")
  campaigns      Campaign[]
  notifications  Notification[]

  @@index([email])
  @@index([role])
}

model Permission {
  id        String   @id @default(uuid())
  userId    String
  module    String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}

model Business {
  id               String   @id @default(uuid())
  name             String
  website          String?
  industry         String?
  city             String?
  country          String?
  phone            String?
  email            String?
  socialProfiles   String?
  companySize      String?
  businessCategory String?
  source           String?
  discoveredAt     DateTime @default(now())

  lead   Lead?
  audit  WebsiteAudit?
  intel  CompanyIntel?
  assets GeneratedAsset[]

  @@index([industry])
  @@index([country])
}

model Lead {
  id                   String   @id @default(uuid())
  businessId           String   @unique
  stage                String   @default("DISCOVERED")
  score                Int      @default(0)
  qualificationScore   Int      @default(0)
  temperature          String   @default("COLD") // HOT, WARM, COLD
  aiAnalysis           String?
  problems             String?
  recommendedSolution  String?
  decisionMaker        String?
  decisionMakerRole    String?
  decisionMakerEmail   String?
  notes                String?
  assignedToId         String?
  campaignId           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation("AssignedTo", fields: [assignedToId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  outreaches Outreach[]
  meetings   Meeting[]
  activities Activity[]

  @@index([stage])
  @@index([assignedToId])
  @@index([businessId])
  @@index([campaignId])
  @@index([temperature])
}

model Outreach {
  id             String    @id @default(uuid())
  leadId         String
  campaignId     String?
  subject        String
  body           String
  status         String    @default("DRAFT")
  type           String    @default("INITIAL")
  followUpNumber Int       @default(0)
  sentAt         DateTime?
  openedAt       DateTime?
  repliedAt      DateTime?
  scheduledFor   DateTime?
  createdAt      DateTime  @default(now())

  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@index([leadId])
  @@index([status])
  @@index([campaignId])
}

model Meeting {
  id          String    @id @default(uuid())
  leadId      String
  title       String
  description String?
  date        DateTime
  duration    Int       @default(30)
  status      String    @default("SCHEDULED")
  location    String?
  meetingLink String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([date])
  @@index([status])
}

model Activity {
  id        String   @id @default(uuid())
  userId    String?
  leadId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// --- NEW MODELS ---

model Campaign {
  id              String   @id @default(uuid())
  name            String
  industry        String?
  targetLocation  String?
  targetCity      String?
  targetSize      String?
  serviceOffering String?
  dailyLimit      Int      @default(20)
  aiModel         String   @default("default")
  notes           String?
  status          String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  leadCount       Int      @default(0)
  sentCount       Int      @default(0)
  replyCount      Int      @default(0)
  meetingCount    Int      @default(0)
  wonCount        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  leads     Lead[]
  outreaches Outreach[]
  analytics  CampaignAnalytics[]

  @@index([ownerId])
  @@index([status])
  @@index([industry])
}

model WebsiteAudit {
  id                  String   @id @default(uuid())
  businessId          String   @unique
  url                 String
  // New 10-category scoring
  uiScore             Int      @default(0)
  uxScore             Int      @default(0)
  seoScore            Int      @default(0)
  performanceScore    Int      @default(0)
  accessibilityScore  Int      @default(0)
  mobileScore         Int      @default(0)
  securityScore       Int      @default(0)
  aiReadinessScore    Int      @default(0)
  automationScore     Int      @default(0)
  conversionScore     Int      @default(0)
  overallScore        Int      @default(0)
  // Detailed analysis (each is a long text with specific findings)
  uiDetails           String?
  uxDetails           String?
  seoDetails          String?
  performanceDetails  String?
  accessibilityDetails String?
  mobileDetails       String?
  securityDetails     String?
  aiReadinessDetails  String?
  automationDetails   String?
  conversionDetails   String?
  // Business intelligence
  executiveSummary    String?
  problemsFound       String?
  opportunities       String?
  recommendations     String?
  pitchStrategy       String?
  talkingPoints       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([overallScore])
}

model LeadProvider {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("custom") // google_places, yelp, custom, serper, scraping
  apiUrl      String?
  apiKey      String?
  authType    String   @default("none") // none, bearer, basic, header, query
  authHeader  String?  // e.g. "X-API-Key"
  authValue   String?
  headers     String?  // JSON string of additional headers
  params      String?  // JSON string of query params
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  priority    Int      @default(0)
  lastUsedAt  DateTime?
  successCount Int     @default(0)
  failCount   Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model PromptTemplate {
  id        String   @id @default(uuid())
  name      String
  category  String   // website_audit, industry_research, lead_qualification, email_generation, sales_strategy, proposal_writing, campaign_analysis
  prompt    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  linkId    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED, ARCHIVED
  triggerType String?  // manual, schedule, webhook, event
  triggerConfig String? // JSON config for trigger
  nodesJson   String?  // JSON - React Flow nodes
  edgesJson   String?  // JSON - React Flow edges
  version     Int      @default(1)
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  errorCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs     WorkflowRun[]
  
  @@index([status])
}

model WorkflowRun {
  id           String   @id @default(uuid())
  workflowId   String
  status       String   @default("RUNNING") // RUNNING, COMPLETED, FAILED, CANCELLED
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  nodeId       String?  // current/failed node
  inputData    String?  // JSON input
  outputData   String?  // JSON output
  errorMessage String?
  duration     Int?     // ms
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
}

model CompanyIntel {
  id                      String   @id @default(uuid())
  businessId              String   @unique
  businessOverview        String?
  coreServices            String?
  idealCustomers          String?
  uniqueSellingProp       String?
  strengths               String?  // JSON array
  weaknesses              String?  // JSON array
  painPoints              String?  // JSON array
  growthOpportunities     String?  // JSON array
  automationOpportunities String?  // JSON array
  aiOpportunities         String?  // JSON array
  trustSignals            String?  // JSON array
  websiteQuality          String?
  estimatedRevenue        String?
  recommendedOutreachStyle String?
  personalizationNotes    String?
  techStack               String?  // JSON array
  competitors             String?  // JSON array
  socialProfiles          String?  // JSON
  teamInfo                String?  // JSON
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model PersonalizationScore {
  id              String   @id @default(uuid())
  businessId      String
  emailId         String?
  overallScore    Int      @default(0) // 0-100
  specificityScore Int     @default(0)
  relevanceScore  Int      @default(0)
  valueScore      Int      @default(0)
  toneScore       Int      @default(0)
  ctaScore        Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([businessId])
  @@index([emailId])
}

model AIMemory {
  id          String   @id @default(uuid())
  userId      String?
  businessId  String?
  category    String   // lead_behavior, email_performance, industry_insight, user_preference, system_learning
  key         String
  value       String   // JSON
  confidence  Float    @default(0.5)
  source      String?  // manual, auto, system
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, key])
  @@index([userId])
  @@index([businessId])
  @@index([category])
}

model CampaignAnalytics {
  id             String   @id @default(uuid())
  campaignId     String
  date           String   // YYYY-MM-DD
  leadsAdded     Int      @default(0)
  emailsSent     Int      @default(0)
  emailsOpened   Int      @default(0)
  emailsReplied  Int      @default(0)
  emailsBounced  Int      @default(0)
  meetingsBooked Int      @default(0)
  dealsWon       Int      @default(0)
  revenue        Float    @default(0)
  createdAt      DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model GeneratedAsset {
  id          String   @id @default(uuid())
  businessId  String?
  leadId      String?
  type        String   // pdf_audit_report, html_demo, growth_blueprint, roi_calculation, sales_pitch
  title       String
  content     String   // HTML/JSON content
  filePath    String?  // path to stored file
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([leadId])
  @@index([type])
}